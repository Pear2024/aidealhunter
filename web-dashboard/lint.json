[{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/admin/agents/page.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/admin/analytics/page.js","messages":[{"ruleId":"@next/next/no-html-link-for-pages","severity":2,"message":"Do not use an `<a>` element to navigate to `/`. Use `<Link />` from `next/link` instead. See: https://nextjs.org/docs/messages/no-html-link-for-pages","line":62,"column":11,"nodeType":"JSXOpeningElement","endLine":62,"endColumn":82}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\nimport { useEffect, useState } from 'react';\n\nexport default function AnalyticsDashboard() {\n  const [stats, setStats] = useState(null);\n  const [loading, setLoading] = useState(true);\n\n  const fetchStats = async () => {\n    try {\n      const res = await fetch('/api/analytics');\n      const data = await res.json();\n      setStats(data);\n    } catch (e) {\n      console.error(e);\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  useEffect(() => {\n    fetchStats();\n  }, []);\n\n  const handleUpdateRevenue = async (id, currentRev) => {\n    const newRev = prompt('Enter new revenue amount ($) for this deal:', currentRev);\n    if (newRev === null) return;\n    \n    const parsedRev = parseFloat(newRev);\n    if (isNaN(parsedRev)) {\n      alert('Invalid number');\n      return;\n    }\n\n    try {\n      await fetch('/api/analytics', {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({ id, revenue: parsedRev })\n      });\n      fetchStats(); // Refresh data\n    } catch (e) {\n      console.error('Failed to update revenue');\n    }\n  };\n\n  if (loading) {\n    return (\n      <div className=\"loader-container\">\n        <div className=\"spinner\"></div>\n        <p>Crunching the numbers...</p>\n      </div>\n    );\n  }\n\n  return (\n    <main className=\"dashboard\">\n      <header className=\"header\" style={{ marginBottom: '40px' }}>\n        <h1>📈 Performance Analytics</h1>\n        <p className=\"subtitle\">Track Clicks & Revenue for your Approved Deals</p>\n        <div style={{ display: 'flex', gap: '20px', justifyContent: 'center', marginTop: '15px' }}>\n          <a href=\"/admin\" style={{ color: 'var(--accent)', textDecoration: 'none' }}>← Back to Review Deals</a>\n          <a href=\"/\" style={{ color: 'var(--accent)', textDecoration: 'none' }}>Go to Storefront ↗</a>\n        </div>\n      </header>\n\n      <div className=\"stats-overview\" style={{ \n        display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(250px, 1fr))', \n        gap: '20px', marginBottom: '40px', maxWidth: '1000px', margin: '0 auto 40px auto' \n      }}>\n        <div className=\"stat-card\" style={{ background: 'var(--card-bg)', padding: '30px', borderRadius: '12px', textAlign: 'center', boxShadow: '0 4px 6px rgba(0,0,0,0.3)' }}>\n          <h3 style={{ color: 'var(--text-muted)', fontSize: '1rem', letterSpacing: '1px', textTransform: 'uppercase' }}>Total Approved Posts</h3>\n          <p style={{ fontSize: '3rem', fontWeight: 'bold', color: 'var(--text-light)', marginTop: '10px' }}>{stats?.totalApproved || 0}</p>\n        </div>\n        <div className=\"stat-card\" style={{ background: 'var(--card-bg)', padding: '30px', borderRadius: '12px', textAlign: 'center', boxShadow: '0 4px 6px rgba(0,0,0,0.3)' }}>\n          <h3 style={{ color: 'var(--text-muted)', fontSize: '1rem', letterSpacing: '1px', textTransform: 'uppercase' }}>Total Link Clicks</h3>\n          <p style={{ fontSize: '3rem', fontWeight: 'bold', color: 'var(--accent)', marginTop: '10px' }}>{stats?.totalClicks || 0}</p>\n        </div>\n        <div className=\"stat-card\" style={{ background: 'var(--card-bg)', padding: '30px', borderRadius: '12px', textAlign: 'center', boxShadow: '0 4px 6px rgba(0,0,0,0.3)' }}>\n          <h3 style={{ color: 'var(--text-muted)', fontSize: '1rem', letterSpacing: '1px', textTransform: 'uppercase' }}>Total Revenue Earned</h3>\n          <p style={{ fontSize: '3rem', fontWeight: 'bold', color: 'var(--success)', marginTop: '10px' }}>\n            ${parseFloat(stats?.totalRevenue || 0).toFixed(2)}\n          </p>\n        </div>\n      </div>\n\n      <div className=\"top-deals-section\" style={{ maxWidth: '1000px', margin: '0 auto' }}>\n        <h2 style={{ marginBottom: '20px', fontSize: '1.5rem', color: 'var(--text-light)' }}>🔥 Top 10 Deals (By Clicks)</h2>\n        \n        {stats?.topDeals && stats.topDeals.length > 0 ? (\n          <div style={{ background: 'var(--card-bg)', borderRadius: '12px', overflow: 'hidden', boxShadow: '0 4px 6px rgba(0,0,0,0.3)' }}>\n            <table style={{ width: '100%', borderCollapse: 'collapse', textAlign: 'left' }}>\n              <thead>\n                <tr style={{ background: 'rgba(255,255,255,0.05)', color: 'var(--text-muted)' }}>\n                  <th style={{ padding: '15px' }}>Deal Title</th>\n                  <th style={{ padding: '15px', textAlign: 'center' }}>Brand</th>\n                  <th style={{ padding: '15px', textAlign: 'center' }}>Clicks</th>\n                  <th style={{ padding: '15px', textAlign: 'right' }}>Revenue / Action</th>\n                </tr>\n              </thead>\n              <tbody>\n                {stats.topDeals.map((deal, idx) => (\n                  <tr key={deal.id} style={{ borderBottom: '1px solid rgba(255,255,255,0.05)', transition: 'background 0.2s', ':hover': { background: 'rgba(255,255,255,0.02)' } }}>\n                    <td style={{ padding: '15px' }}>\n                      <div style={{ fontWeight: 'bold', marginBottom: '5px' }}>{deal.title}</div>\n                      <a href={deal.url} target=\"_blank\" rel=\"noopener noreferrer\" style={{ color: 'var(--accent)', fontSize: '0.85rem', textDecoration: 'none' }}>View Source ↗</a>\n                    </td>\n                    <td style={{ padding: '15px', textAlign: 'center', color: 'var(--text-muted)' }}>{deal.brand}</td>\n                    <td style={{ padding: '15px', textAlign: 'center', fontWeight: 'bold', fontSize: '1.2rem', color: 'var(--accent)' }}>{deal.clicks}</td>\n                    <td style={{ padding: '15px', textAlign: 'right' }}>\n                      <div style={{ fontWeight: 'bold', color: 'var(--success)', fontSize: '1.1rem', marginBottom: '8px' }}>\n                        ${parseFloat(deal.earned_revenue).toFixed(2)}\n                      </div>\n                      <button \n                        onClick={() => handleUpdateRevenue(deal.id, deal.earned_revenue)}\n                        style={{ background: 'transparent', border: '1px solid var(--text-muted)', color: 'var(--text-light)', padding: '5px 10px', borderRadius: '4px', cursor: 'pointer', fontSize: '0.8rem' }}\n                      >\n                        ✏️ Update\n                      </button>\n                    </td>\n                  </tr>\n                ))}\n              </tbody>\n            </table>\n          </div>\n        ) : (\n          <div className=\"empty-state\">\n            <p>No approved deals yet. Start approving deals to see stats!</p>\n          </div>\n        )}\n      </div>\n    </main>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/admin/page.js","messages":[{"ruleId":"@next/next/no-html-link-for-pages","severity":2,"message":"Do not use an `<a>` element to navigate to `/`. Use `<Link />` from `next/link` instead. See: https://nextjs.org/docs/messages/no-html-link-for-pages","line":60,"column":11,"nodeType":"JSXOpeningElement","endLine":60,"endColumn":82},{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":100,"column":11,"nodeType":"JSXOpeningElement","endLine":100,"endColumn":72}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\nimport { useEffect, useState } from 'react';\n\nexport default function AdminDashboard() {\n  const [deals, setDeals] = useState([]);\n  const [loading, setLoading] = useState(true);\n\n  const fetchDeals = async () => {\n    try {\n      const res = await fetch('/api/deals?status=pending');\n      const data = await res.json();\n      setDeals(data.deals || []);\n    } catch (e) {\n      console.error(e);\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  useEffect(() => {\n    fetchDeals();\n  }, []);\n\n  const handleAction = async (id, action, currentData) => {\n    setDeals(deals.filter(d => d.id !== id)); // Optimistic UI update\n    \n    try {\n      await fetch('/api/deals', {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n        },\n        body: JSON.stringify({\n          id,\n          action,\n          data: currentData\n        }),\n      });\n    } catch (e) {\n      console.error(e);\n      fetchDeals(); // Revert on failure\n    }\n  };\n\n  if (loading) {\n    return (\n      <div className=\"loader-container\">\n        <div className=\"spinner\"></div>\n        <p>Hunting for deals...</p>\n      </div>\n    );\n  }\n\n  return (\n    <main className=\"dashboard\">\n      <header className=\"header\">\n        <h1>🎯 AI Deal Hunter</h1>\n        <p className=\"subtitle\">Admin Review Dashboard (Secret URL)</p>\n        <div style={{ display: 'flex', gap: '20px', justifyContent: 'center', marginTop: '15px' }}>\n          <a href=\"/\" style={{ color: 'var(--accent)', textDecoration: 'none' }}>← Go back to Public Storefront</a>\n          <a href=\"/admin/analytics\" style={{ color: 'var(--success)', textDecoration: 'none' }}>View Analytics 📈</a>\n          <a href=\"/admin/agents\" style={{ color: '#ff9a9e', textDecoration: 'none', fontWeight: 'bold' }}>AI Overlord 🌌 →</a>\n        </div>\n      </header>\n\n      <SearchModule onSearchComplete={fetchDeals} />\n\n      {deals.length === 0 ? (\n        <div className=\"empty-state\">\n          <div className=\"empty-icon\">🎉</div>\n          <h2>All Caught Up!</h2>\n          <p>No pending deals left to review. Great job.</p>\n        </div>\n      ) : (\n        <div className=\"stats-bar\">\n          <span className=\"badge\">{deals.length} Pending Review</span>\n        </div>\n      )}\n\n      <div className=\"deal-grid\">\n        {deals.map(deal => (\n          <DealCard key={deal.id} deal={deal} onAction={handleAction} />\n        ))}\n      </div>\n    </main>\n  );\n}\n\nfunction DealCard({ deal, onAction }) {\n  const [title, setTitle] = useState(deal.title || '');\n  const [brand, setBrand] = useState(deal.brand || '');\n  const [origPrice, setOrigPrice] = useState(deal.original_price || '');\n  const [discPrice, setDiscPrice] = useState(deal.discount_price || '');\n\n  return (\n    <div className=\"deal-card fade-in\">\n      <div className=\"card-image-wrapper\">\n        <div className=\"confidence-badge\">Score: {deal.confidence_score}</div>\n        {deal.image_url ? (\n          <img src={deal.image_url} alt=\"Deal\" className=\"deal-image\"/>\n        ) : (\n          <div className=\"no-image\">No Image Found</div>\n        )}\n      </div>\n      \n      <div className=\"card-content\">\n        <a href={deal.url} target=\"_blank\" rel=\"noopener noreferrer\" className=\"original-link\">View Original Source ↗</a>\n        \n        <div className=\"form-group\">\n          <label>Product Title</label>\n          <input value={title} onChange={(e) => setTitle(e.target.value)} />\n        </div>\n        \n        <div className=\"form-group\">\n          <label>Brand</label>\n          <input value={brand} onChange={(e) => setBrand(e.target.value)} />\n        </div>\n\n        <div className=\"price-row\">\n          <div className=\"form-group\">\n            <label>Original Price ($)</label>\n            <input type=\"number\" step=\"0.01\" value={origPrice} onChange={(e) => setOrigPrice(e.target.value)} />\n          </div>\n          <div className=\"form-group\">\n            <label>Discount Price ($)</label>\n            <input type=\"number\" step=\"0.01\" value={discPrice} onChange={(e) => setDiscPrice(e.target.value)} />\n          </div>\n        </div>\n\n        <div className=\"action-buttons\">\n          <button \n            className=\"btn btn-reject\" \n            onClick={() => onAction(deal.id, 'reject')}\n          >\n            ❌ Reject\n          </button>\n          <button \n            className=\"btn btn-approve\"\n            onClick={() => onAction(deal.id, 'approve', { title, brand, original_price: origPrice, discount_price: discPrice })}\n          >\n            ✅ Approve\n          </button>\n        </div>\n      </div>\n    </div>\n  );\n}\n\nfunction SearchModule({ onSearchComplete }) {\n  const [keyword, setKeyword] = useState('');\n  const [isSearching, setIsSearching] = useState(false);\n\n  const handleSearch = async () => {\n    if (!keyword.trim()) return;\n    setIsSearching(true);\n    try {\n      const res = await fetch('/api/deals/search', {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({ keyword })\n      });\n      const data = await res.json();\n      if (data.added > 0) {\n        alert(`Success! Found and added ${data.added} new deals for \"${keyword}\".\\\\nThey are now available below for your review.`);\n        onSearchComplete(); \n      } else {\n        alert(data.message || 'No new deals found or they might be duplicates/rate-limited.');\n      }\n    } catch (e) {\n      console.error(e);\n      alert('Error searching for deals. Check console.');\n    } finally {\n      setIsSearching(false);\n      setKeyword('');\n    }\n  };\n\n  return (\n    <div className=\"search-module slide-down fade-in\" style={{ background: 'var(--card-bg)', padding: '20px', borderRadius: '12px', maxWidth: '600px', margin: '0 auto 30px auto', display: 'flex', gap: '10px', boxShadow: '0 4px 6px rgba(0,0,0,0.3)', border: '1px solid rgba(255,255,255,0.05)' }}>\n      <input \n        type=\"text\" \n        placeholder=\"Enter product (e.g. iPad, Sony, Laptop)...\" \n        value={keyword}\n        onChange={(e) => setKeyword(e.target.value)}\n        disabled={isSearching}\n        style={{ flex: 1, padding: '12px', borderRadius: '8px', border: '1px solid #444', background: '#222', color: 'white', fontSize: '1rem' }}\n        onKeyDown={(e) => { if (e.key === 'Enter') handleSearch() }}\n      />\n      <button \n        onClick={handleSearch} \n        disabled={isSearching}\n        style={{ padding: '0 25px', background: isSearching ? '#555' : 'var(--accent)', color: 'white', border: 'none', borderRadius: '8px', fontWeight: 'bold', cursor: isSearching ? 'not-allowed' : 'pointer', transition: 'background 0.2s', fontSize: '1rem' }}\n      >\n        {isSearching ? '🤖 Hunting...' : '🤖 Hunt Deals!'}\n      </button>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/api/admin/agents/route.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/api/analytics/route.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/api/blog/comments/route.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/api/cron/blog/route.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/api/cron/deals/route.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/api/cron/engagement/route.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/api/deals/route.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/api/deals/search/route.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/api/deals/submit/route.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/api/deals/vote/route.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/api/migrate/route.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/api/profile/route.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/api/webhooks/facebook/route.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/blog/[slug]/Comments.js","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'fetchComments'. Either include it or remove the dependency array.","line":23,"column":8,"nodeType":"ArrayExpression","endLine":23,"endColumn":16,"suggestions":[{"desc":"Update the dependencies array to be: [fetchComments, postId]","fix":{"range":[792,800],"text":"[fetchComments, postId]"}}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\nimport { useState, useEffect } from 'react';\nimport { SignInButton, useUser } from '@clerk/nextjs';\n\nexport default function Comments({ postId }) {\n    const { isSignedIn, user } = useUser();\n    const [comments, setComments] = useState([]);\n    const [newComment, setNewComment] = useState(\"\");\n    const [loading, setLoading] = useState(true);\n    const [submitting, setSubmitting] = useState(false);\n\n    const fetchComments = async () => {\n        try {\n            const res = await fetch(`/api/blog/comments?postId=${postId}`);\n            const data = await res.json();\n            if (data.comments) setComments(data.comments);\n        } catch(e) { console.error(e); }\n        finally { setLoading(false); }\n    };\n\n    useEffect(() => {\n        fetchComments();\n    }, [postId]);\n\n    const handleSubmit = async (e) => {\n        e.preventDefault();\n        if (!newComment.trim() || !isSignedIn) return;\n        setSubmitting(true);\n        try {\n            const res = await fetch('/api/blog/comments', {\n                method: 'POST',\n                headers: { 'Content-Type': 'application/json' },\n                body: JSON.stringify({ \n                    postId, \n                    userName: user.fullName || user.firstName || 'Anonymous', \n                    userId: user.id, \n                    commentText: newComment \n                })\n            });\n            if (res.ok) {\n                setNewComment(\"\");\n                fetchComments(); // Refresh list\n            }\n        } catch(e) { console.error(e); }\n        finally { setSubmitting(false); }\n    };\n\n    return (\n        <div>\n            {loading ? <p style={{ color: '#888' }}>Loading comments...</p> : (\n                <div style={{ marginBottom: '2rem' }}>\n                    {comments.length === 0 ? <p style={{ color: '#888', fontStyle: 'italic' }}>Be the first to share your thoughts!</p> : (\n                        <div style={{ display: 'flex', flexDirection: 'column', gap: '15px' }}>\n                            {comments.map(c => (\n                                <div key={c.id} style={{ background: 'rgba(255,255,255,0.05)', padding: '15px', borderRadius: '10px', borderLeft: '4px solid #ff3366' }}>\n                                    <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: '8px' }}>\n                                        <strong style={{ color: '#fff' }}>{c.user_name}</strong>\n                                        <span style={{ fontSize: '0.8rem', color: '#888' }}>{new Date(c.created_at).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute:'2-digit' })}</span>\n                                    </div>\n                                    <p style={{ color: '#ddd', margin: 0, lineHeight: '1.5' }}>{c.comment_text}</p>\n                                </div>\n                            ))}\n                        </div>\n                    )}\n                </div>\n            )}\n\n            <div style={{ background: 'rgba(0,0,0,0.2)', padding: '20px', borderRadius: '15px', border: '1px solid rgba(255,255,255,0.1)' }}>\n                {!isSignedIn ? (\n                    <div style={{ textAlign: 'center', padding: '1rem' }}>\n                        <p style={{ color: '#aaa', marginBottom: '1rem' }}>Join the conversation! You must be logged in to post a comment.</p>\n                        <SignInButton mode=\"modal\">\n                            <button className=\"btn-primary\" style={{ padding: '10px 25px', borderRadius: '30px', fontWeight: 'bold' }}>Sign in to Comment</button>\n                        </SignInButton>\n                    </div>\n                ) : (\n                    <form onSubmit={handleSubmit}>\n                        <div style={{ marginBottom: '10px', color: '#ffcc80', fontSize: '0.9rem' }}>\n                            Posting publicly as: <strong>{user.fullName || user.firstName || 'Shopper'}</strong>\n                        </div>\n                        <textarea \n                            value={newComment}\n                            onChange={(e) => setNewComment(e.target.value)}\n                            placeholder=\"Share your opinions, tips, or questions here...\"\n                            rows={4}\n                            required\n                            style={{ width: '100%', background: 'rgba(255,255,255,0.05)', color: 'white', border: '1px solid rgba(255,255,255,0.2)', padding: '15px', borderRadius: '10px', fontFamily: 'inherit', resize: 'vertical' }}\n                        />\n                        <div style={{ textAlign: 'right', marginTop: '15px' }}>\n                            <button type=\"submit\" disabled={submitting || !newComment.trim()} className=\"btn-primary\" style={{ padding: '10px 30px', borderRadius: '30px', fontWeight: 'bold', opacity: submitting ? 0.7 : 1, cursor: submitting ? 'wait' : 'pointer' }}>\n                                {submitting ? 'Posting...' : 'Post Comment'}\n                            </button>\n                        </div>\n                    </form>\n                )}\n            </div>\n        </div>\n    );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/blog/[slug]/page.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/blog/page.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/components/AdBanner.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/layout.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/page.js","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has a missing dependency: 'loadDeals'. Either include it or remove the dependency array.","line":93,"column":6,"nodeType":"ArrayExpression","endLine":93,"endColumn":17,"suggestions":[{"desc":"Update the dependencies array to be: [activeTab, loadDeals]","fix":{"range":[3725,3736],"text":"[activeTab, loadDeals]"}}]},{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":165,"column":11,"nodeType":"JSXOpeningElement","endLine":165,"endColumn":102},{"ruleId":"react/no-unescaped-entities","severity":2,"message":"`'` can be escaped with `&apos;`, `&lsquo;`, `&#39;`, `&rsquo;`.","line":345,"column":178,"nodeType":"JSXText","messageId":"unescapedEntityAlts","suggestions":[{"messageId":"replaceWithAlt","data":{"alt":"&apos;"},"fix":{"range":[17558,17814],"text":"Product prices and availability are accurate as of the date/time indicated and are subject to change. Any price and availability information displayed on the merchant&apos;s site (e.g., Amazon) at the time of purchase will apply to the purchase of this product."},"desc":"Replace with `&apos;`."},{"messageId":"replaceWithAlt","data":{"alt":"&lsquo;"},"fix":{"range":[17558,17814],"text":"Product prices and availability are accurate as of the date/time indicated and are subject to change. Any price and availability information displayed on the merchant&lsquo;s site (e.g., Amazon) at the time of purchase will apply to the purchase of this product."},"desc":"Replace with `&lsquo;`."},{"messageId":"replaceWithAlt","data":{"alt":"&#39;"},"fix":{"range":[17558,17814],"text":"Product prices and availability are accurate as of the date/time indicated and are subject to change. Any price and availability information displayed on the merchant&#39;s site (e.g., Amazon) at the time of purchase will apply to the purchase of this product."},"desc":"Replace with `&#39;`."},{"messageId":"replaceWithAlt","data":{"alt":"&rsquo;"},"fix":{"range":[17558,17814],"text":"Product prices and availability are accurate as of the date/time indicated and are subject to change. Any price and availability information displayed on the merchant&rsquo;s site (e.g., Amazon) at the time of purchase will apply to the purchase of this product."},"desc":"Replace with `&rsquo;`."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\nimport { useEffect, useState } from 'react';\nimport { SignInButton, UserButton, useUser } from '@clerk/nextjs';\n\nexport default function Storefront() {\n  const { isSignedIn } = useUser();\n  const [latestDeals, setLatestDeals] = useState([]);\n  const [recommendedDeals, setRecommendedDeals] = useState([]);\n  const [loading, setLoading] = useState(true);\n  const [userSegment, setUserSegment] = useState(null);\n  const [activeTab, setActiveTab] = useState('all');\n  const [page, setPage] = useState(1);\n  const [hasMore, setHasMore] = useState(true);\n  const [loadingMore, setLoadingMore] = useState(false);\n\n  const loadDeals = async (pageNum, reset = false) => {\n      if (reset) setLoading(true);\n      else setLoadingMore(true);\n\n      const getCookie = (name) => {\n        const match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));\n        if (match) return match[2];\n        return null;\n      };\n      const preferredBrand = getCookie('preferred_brand');\n\n      try {\n        const res = await fetch(`/api/deals?status=all&category=${activeTab}&page=${pageNum}`);\n        const data = await res.json();\n        const sortedDeals = (data.deals || []).sort((a, b) => (b.merchandiser_score || 0) - (a.merchandiser_score || 0));\n        \n        if (sortedDeals.length < 50) setHasMore(false);\n        else setHasMore(true);\n\n        if (!reset) {\n            setLatestDeals(prev => {\n                const existingIds = new Set(prev.map(d => d.id));\n                const uniqueNew = sortedDeals.filter(d => !existingIds.has(d.id));\n                return [...prev, ...uniqueNew];\n            });\n            return;\n        }\n\n        // --- PHASE 20: Taste Profiler Driven Sorting (Page 1 Only) ---\n        const seg = data.visitorSegment;\n        if (seg) {\n            setUserSegment(seg);\n            const lowSeg = seg.toLowerCase();\n            const recommendList = [];\n            const otherList = [];\n            \n            for (const d of sortedDeals) {\n               const textToMatch = `${d.title} ${d.brand} ${d.url}`.toLowerCase();\n               const segWords = lowSeg.split(' ').filter(w => w.length > 3 && !['under', 'lovers', 'moms', 'hunters', 'fans'].includes(w));\n               \n               let isMatch = false;\n               for (const word of segWords) {\n                  if (textToMatch.includes(word)) { isMatch = true; break; }\n               }\n               \n               if (lowSeg.includes('clearance') || lowSeg.includes('budget') || lowSeg.includes('cheap')) {\n                   const original = parseFloat(d.original_price);\n                   const discounted = parseFloat(d.discount_price);\n                   if (original && discounted && (1 - discounted / original) > 0.4) isMatch = true;\n               }\n               \n               if (isMatch) recommendList.push(d);\n               else otherList.push(d);\n            }\n            \n            if (recommendList.length > 0) {\n                setRecommendedDeals(recommendList);\n                setLatestDeals(otherList);\n            } else setLatestDeals(sortedDeals);\n        } else if (preferredBrand) {\n           const decodedBrand = decodeURIComponent(preferredBrand).toLowerCase();\n           setRecommendedDeals(sortedDeals.filter(d => d.brand?.toLowerCase() === decodedBrand));\n           setLatestDeals(sortedDeals.filter(d => d.brand?.toLowerCase() !== decodedBrand));\n        } else {\n           setLatestDeals(sortedDeals);\n        }\n      } catch (e) { console.error(e); } \n      finally {\n        if (reset) setLoading(false);\n        else setLoadingMore(false);\n      }\n    };\n\n  useEffect(() => {\n    setPage(1);\n    setHasMore(true);\n    loadDeals(1, true);\n  }, [activeTab]);\n\n  const handleLoadMore = () => {\n    const nextPage = page + 1;\n    setPage(nextPage);\n    loadDeals(nextPage, false);\n  };\n\n\n  const handleVote = async (e, dealId) => {\n    e.stopPropagation();\n    if (!isSignedIn) {\n      alert(\"Please sign in to vote! 💖\");\n      return;\n    }\n\n    // Optimistic UI updates could be added here, but doing straightforward refresh for simplicity.\n    try {\n      const res = await fetch('/api/deals/vote', {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({ dealId, voteType: 1 }) // 1 is Upvote\n      });\n      const data = await res.json();\n      \n      if (res.ok) {\n        setRecommendedDeals(recommendedDeals.map(d => d.id === dealId ? { ...d, vote_score: data.newScore } : d));\n        setLatestDeals(latestDeals.map(d => d.id === dealId ? { ...d, vote_score: data.newScore } : d));\n      } else {\n        alert(data.error);\n      }\n    } catch (err) {\n      console.error(err);\n    }\n  };\n\n  if (loading) {\n    return (\n      <div className=\"loader-container\">\n        <div className=\"spinner\"></div>\n        <p>Finding the best discounts for you...</p>\n      </div>\n    );\n  }\n\n  const getRetailerInfo = (url) => {\n    if (!url) return { name: 'Unknown', color: '#666' };\n    const lowerUrl = url.toLowerCase();\n    if (lowerUrl.includes('amazon')) return { name: 'Amazon', color: '#FF9900' };\n    if (lowerUrl.includes('walmart')) return { name: 'Walmart', color: '#0071CE' };\n    if (lowerUrl.includes('target')) return { name: 'Target', color: '#CC0000' };\n    if (lowerUrl.includes('costco')) return { name: 'Costco', color: '#005DAA' };\n    if (lowerUrl.includes('bestbuy') || lowerUrl.includes('best buy')) return { name: 'Best Buy', color: '#0046BE' };\n    return { name: 'Retailer', color: '#666' };\n  };\n\n  const renderDeal = (deal) => {\n    const isExpired = deal.status === 'expired';\n    return (\n    <div key={deal.id} className=\"deal-card fade-in\" style={{ cursor: isExpired ? 'not-allowed' : 'pointer', background: 'rgba(255, 255, 255, 0.03)', opacity: isExpired ? 0.6 : 1, filter: isExpired ? 'grayscale(80%)' : 'none' }} onClick={() => !isExpired && window.open('/r/' + deal.id, '_blank')}>\n      <div className=\"card-image-wrapper\">\n         {isExpired && (\n             <div style={{ position: 'absolute', top: 0, left: 0, right: 0, bottom: 0, background: 'rgba(0,0,0,0.5)', display: 'flex', alignItems: 'center', justifyContent: 'center', zIndex: 10 }}>\n                 <span style={{ color: 'white', fontWeight: 'bold', fontSize: '1.5rem', border: '3px solid white', padding: '10px 20px', transform: 'rotate(-15deg)' }}>EXPIRED</span>\n             </div>\n         )}\n         {deal.discount_price && deal.original_price && deal.original_price > deal.discount_price && !isExpired && (\n            <div style={{ position: 'absolute', top: '12px', right: '12px', zIndex: 10 }}>\n              <span className=\"premium-badge\" style={{ boxShadow: '0 4px 12px rgba(0,0,0,0.4)', border: '1px solid rgba(255,255,255,0.2)' }}>{Math.round((1 - deal.discount_price / deal.original_price) * 100)}% OFF</span>\n            </div>\n         )}\n         {deal.image_url ? (\n          <img src={deal.image_url} alt=\"Deal\" className=\"deal-image\" referrerPolicy=\"no-referrer\" />\n        ) : (\n          <div className=\"no-image\">No Image</div>\n        )}\n      </div>\n      <div className=\"card-content\">\n        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', marginBottom: '0.5rem' }}>\n            <h3 style={{ fontSize: '1.15rem', margin: '0 0 10px 0', lineHeight: '1.5', fontWeight: '700', overflow: 'hidden', textOverflow: 'ellipsis', display: '-webkit-box', WebkitLineClamp: 2, WebkitBoxOrient: 'vertical' }}>\n              {deal.title.replace(/\\[DEMO\\]\\s*/g, '')}\n            </h3>\n        </div>\n        <div style={{ display: 'flex', alignItems: 'center', gap: '8px', marginBottom: '1rem', flexWrap: 'wrap' }}>\n           {(() => {\n             const { name, color } = getRetailerInfo(deal.url);\n             return (\n               <span style={{ background: color, color: 'white', padding: '2px 8px', borderRadius: '4px', fontSize: '0.8rem', fontWeight: 'bold' }}>\n                 {name}\n               </span>\n             );\n           })()}\n           {deal.brand && <span style={{ color: 'var(--text-secondary)', fontSize: '0.9rem' }}>By {deal.brand}</span>}\n        </div>\n        \n        <div style={{ marginTop: 'auto', paddingTop: '1rem', display: 'flex', justifyContent: 'space-between', alignItems: 'flex-end', borderTop: '1px solid rgba(255,255,255,0.05)' }}>\n          <div style={{ display: 'flex', flexDirection: 'column' }}>\n            <div style={{ display: 'flex', alignItems: 'baseline' }}>\n                {deal.discount_price && <span className=\"discount-text\" style={{ fontSize: '1.8rem', color: isExpired ? '#888' : 'inherit' }}>${parseFloat(deal.discount_price).toFixed(2)}</span>}\n                {deal.original_price && <span style={{ fontSize: '1rem', textDecoration: 'line-through', color: 'var(--text-secondary)', marginLeft: '10px' }}>${parseFloat(deal.original_price).toFixed(2)}</span>}\n            </div>\n            {deal.installment_plan && !isExpired && (\n                <div style={{ fontSize: '0.8rem', color: '#00D084', marginTop: '2px', fontWeight: 'bold', display: 'flex', alignItems: 'center', gap: '4px' }}>\n                    <svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" strokeWidth=\"3\" strokeLinecap=\"round\" strokeLinejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"></polyline></svg>\n                    💳 {deal.installment_plan}\n                </div>\n            )}\n          </div>\n          \n          <div style={{ display: 'flex', gap: '10px', alignItems: 'center' }}>\n            <button \n              className=\"vote-btn\"\n              onClick={(e) => { if(!isExpired) handleVote(e, deal.id); }}\n              disabled={isExpired}\n              style={{ background: 'rgba(255,255,255,0.05)', border: '1px solid rgba(255,255,255,0.1)', borderRadius: '12px', padding: '10px 14px', color: isExpired ? '#888' : 'white', cursor: isExpired ? 'not-allowed' : 'pointer', display: 'flex', alignItems: 'center', justifyContent: 'center', gap: '5px', fontWeight: 'bold', minWidth: '60px' }}\n            >\n              🔥 <span style={{fontSize:'0.95rem'}}>{deal.vote_score || 0}</span>\n            </button>\n            {isExpired ? (\n                <button className=\"premium-buy-btn\" disabled>Ended ⏳</button>\n            ) : (\n                <button className=\"premium-buy-btn\" onClick={(e) => { e.stopPropagation(); window.open('/r/' + deal.id, '_blank'); }}>Get Deal 🛒</button>\n            )}\n          </div>\n        </div>\n      </div>\n    </div>\n  )};\n\n  return (\n    <>\n      <nav style={{ \n        position: 'sticky', top: 0, zIndex: 100, \n        background: 'rgba(5, 5, 5, 0.7)', backdropFilter: 'var(--glass-blur)', WebkitBackdropFilter: 'var(--glass-blur)',\n        borderBottom: '1px solid var(--card-border)', padding: '15px 0'\n      }}>\n        <div style={{ maxWidth: '1200px', margin: '0 auto', padding: '0 2rem', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>\n          <div style={{ fontWeight: '800', fontSize: '1.4rem', letterSpacing: '-0.5px', display: 'flex', alignItems: 'center', gap: '8px' }}>\n            <span style={{ fontSize: '1.8rem' }}>💎</span> \n            <span style={{ background: 'var(--accent-gradient)', WebkitBackgroundClip: 'text', WebkitTextFillColor: 'transparent' }}>DealHunter Pro</span>\n          </div>\n          <div>\n            {!isSignedIn ? (\n              <SignInButton mode=\"modal\">\n                <button className=\"btn-outline\">Sign In</button>\n              </SignInButton>\n            ) : (\n              <div style={{ display: 'flex', alignItems: 'center', gap: '15px' }}>\n                <a href=\"/submit\" className=\"btn-outline\" style={{ textDecoration: 'none', fontSize: '0.9rem' }}>+ Submit Deal</a>\n                <UserButton afterSignOutUrl=\"/\" />\n              </div>\n            )}\n          </div>\n        </div>\n      </nav>\n\n      <main className=\"dashboard\" style={{ paddingTop: '2rem' }}>\n        <section style={{ \n          textAlign: 'center', marginBottom: '4rem', padding: '4rem 2rem', \n          background: 'radial-gradient(circle at 50% 0%, rgba(255, 51, 102, 0.15) 0%, transparent 70%)',\n          borderRadius: '30px', position: 'relative', overflow: 'hidden'\n        }} className=\"fade-in\">\n          <div style={{ position: 'absolute', top: '-50%', left: '-10%', width: '400px', height: '400px', background: 'var(--accent)', filter: 'blur(120px)', opacity: 0.15, borderRadius: '50%' }}></div>\n          <div style={{ position: 'absolute', bottom: '-50%', right: '-10%', width: '300px', height: '300px', background: '#FF9933', filter: 'blur(100px)', opacity: 0.15, borderRadius: '50%' }}></div>\n          \n          <div style={{ display: 'inline-block', marginBottom: '1.5rem', border: '1px solid rgba(255,51,102,0.3)', padding: '6px 16px', borderRadius: '20px', background: 'rgba(255,51,102,0.1)', color: '#ff99a8', fontSize: '0.9rem', fontWeight: 'bold', letterSpacing: '1px' }}>\n             🚀 UP TO 90% OFF PREMIUM BRANDS \n          </div>\n          <h1 style={{ fontSize: '3.5rem', fontWeight: '800', marginBottom: '1rem', letterSpacing: '-1px', lineHeight: '1.2' }}>\n            Discover Unbeatable <br/>\n            <span style={{ background: 'var(--accent-gradient)', WebkitBackgroundClip: 'text', WebkitTextFillColor: 'transparent' }}>Exclusive Deals</span>\n          </h1>\n          <p style={{ color: 'var(--text-secondary)', fontSize: '1.2rem', maxWidth: '600px', margin: '0 auto', lineHeight: '1.6' }}>\n            Premium, hand-picked discounts powered by AI. Save big on top brands with our real-time deal engine.\n          </p>\n        </section>\n\n      {/* PHASE 16: FTC Affiliate Disclosure Banner */}\n      <div style={{ background: 'rgba(255, 255, 255, 0.05)', padding: '12px 20px', textAlign: 'center', fontSize: '0.9rem', color: '#ccc', marginBottom: '2rem', borderRadius: '8px', border: '1px solid rgba(255, 255, 255, 0.1)' }}>\n        <strong>Affiliate Disclosure:</strong> As an Amazon Associate, I earn from qualifying purchases. We may earn a small commission if you buy through our links, at no extra cost to you.\n      </div>\n      \n      {/* PHASE 32: Categorical Navigation Tabs */}\n      <div style={{ display: 'flex', justifyContent: 'center', gap: '15px', marginBottom: '3rem', flexWrap: 'wrap' }} className=\"fade-in\">\n        {['all', 'food', 'household', 'tech', 'travel'].map(tab => (\n           <button \n             key={tab} \n             onClick={() => setActiveTab(tab)}\n             style={{\n               background: activeTab === tab ? 'var(--accent-gradient)' : 'rgba(255,255,255,0.05)',\n               border: activeTab === tab ? 'none' : '1px solid rgba(255,255,255,0.1)',\n               color: activeTab === tab ? 'white' : '#aaa',\n               padding: '10px 24px',\n               borderRadius: '30px',\n               fontSize: '1rem',\n               fontWeight: 'bold',\n               cursor: 'pointer',\n               textTransform: 'capitalize',\n               transition: 'all 0.3s ease',\n               boxShadow: activeTab === tab ? '0 4px 15px rgba(255,51,102,0.4)' : 'none'\n             }}>\n             {tab === 'all' ? 'All Deals' : tab}\n           </button>\n        ))}\n      </div>\n      \n      {(latestDeals.length === 0 && recommendedDeals.length === 0) ? (\n        <div className=\"empty-state\">\n          <div className=\"empty-icon\">⏳</div>\n          <h2>Hunting for new deals...</h2>\n          <p>Check back soon for the latest massive discounts.</p>\n        </div>\n      ) : (\n        <>\n          {recommendedDeals.length > 0 && (\n            <div style={{ marginBottom: '3rem' }}>\n              <h2 style={{ color: '#ff8a00', marginBottom: '1.5rem', display: 'flex', alignItems: 'center', gap: '10px' }}>\n                <span style={{ fontSize: '1.8rem' }}>🎯</span> Recommended For You\n                {userSegment && <span style={{ fontSize: '0.9rem', color: '#ffcc80', border: '1px solid #ffcc80', padding: '2px 8px', borderRadius: '12px', marginLeft: 'auto' }}>{userSegment}</span>}\n              </h2>\n              <div className=\"deal-grid\">\n                {recommendedDeals.map(deal => renderDeal(deal))}\n              </div>\n            </div>\n          )}\n          \n          <div>\n              <h2 style={{ marginBottom: '1.5rem', display: 'flex', alignItems: 'center', gap: '10px', color: '#fff' }}>\n                <span style={{ fontSize: '1.8rem' }}>⚡</span> Latest Deals\n              </h2>\n              <div className=\"deal-grid\">\n                {latestDeals.map(deal => renderDeal(deal))}\n              </div>\n          </div>\n          \n          {hasMore && (\n              <div style={{ textAlign: 'center', marginTop: '3rem', marginBottom: '2rem' }}>\n                  <button \n                      onClick={handleLoadMore} \n                      disabled={loadingMore}\n                      className=\"btn-outline\" \n                      style={{ padding: '12px 30px', fontSize: '1.1rem', background: loadingMore ? 'rgba(255,255,255,0.05)' : 'transparent', cursor: loadingMore ? 'wait' : 'pointer' }}\n                  >\n                      {loadingMore ? 'Loading hidden gems... 💎' : 'Load More Deals 👇'}\n                  </button>\n              </div>\n          )}\n        </>\n      )}\n\n      {/* PHASE 16: Amazon Price Disclaimer Footer */}\n      <footer style={{ marginTop: '4rem', padding: '2rem 0', borderTop: '1px solid rgba(255, 255, 255, 0.1)', textAlign: 'center', color: '#888', fontSize: '0.85rem', lineHeight: '1.5' }}>\n        <p>Product prices and availability are accurate as of the date/time indicated and are subject to change. Any price and availability information displayed on the merchant's site (e.g., Amazon) at the time of purchase will apply to the purchase of this product.</p>\n        <p style={{ marginTop: '10px' }}>&copy; {new Date().getFullYear()} DealHunter Pro. All rights reserved.</p>\n      </footer>\n    </main>\n    </>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/profile/page.js","messages":[{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":57,"column":11,"nodeType":"JSXOpeningElement","endLine":61,"endColumn":13},{"ruleId":"react/no-unescaped-entities","severity":2,"message":"`'` can be escaped with `&apos;`, `&lsquo;`, `&#39;`, `&rsquo;`.","line":102,"column":89,"nodeType":"JSXText","messageId":"unescapedEntityAlts","suggestions":[{"messageId":"replaceWithAlt","data":{"alt":"&apos;"},"fix":{"range":[5048,5084],"text":"You haven&apos;t submitted any deals yet."},"desc":"Replace with `&apos;`."},{"messageId":"replaceWithAlt","data":{"alt":"&lsquo;"},"fix":{"range":[5048,5084],"text":"You haven&lsquo;t submitted any deals yet."},"desc":"Replace with `&lsquo;`."},{"messageId":"replaceWithAlt","data":{"alt":"&#39;"},"fix":{"range":[5048,5084],"text":"You haven&#39;t submitted any deals yet."},"desc":"Replace with `&#39;`."},{"messageId":"replaceWithAlt","data":{"alt":"&rsquo;"},"fix":{"range":[5048,5084],"text":"You haven&rsquo;t submitted any deals yet."},"desc":"Replace with `&rsquo;`."}]},{"ruleId":"@next/next/no-img-element","severity":1,"message":"Using `<img>` could result in slower LCP and higher bandwidth. Consider using `<Image />` from `next/image` or a custom image loader to automatically optimize images. This may incur additional usage or cost from your provider. See: https://nextjs.org/docs/messages/no-img-element","line":120,"column":21,"nodeType":"JSXOpeningElement","endLine":120,"endColumn":130}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\n\nimport { useState, useEffect } from 'react';\nimport { useUser } from '@clerk/nextjs';\nimport Link from 'next/link';\n\nexport default function ProfilePage() {\n  const { isLoaded, isSignedIn, user } = useUser();\n  const [profileData, setProfileData] = useState(null);\n  const [loading, setLoading] = useState(true);\n\n  useEffect(() => {\n    if (isLoaded && isSignedIn) {\n      fetchProfileData();\n    } else if (isLoaded && !isSignedIn) {\n      setLoading(false);\n    }\n  }, [isLoaded, isSignedIn]);\n\n  const fetchProfileData = async () => {\n    try {\n      const res = await fetch('/api/profile');\n      const data = await res.json();\n      if (res.ok) {\n        setProfileData(data);\n      }\n    } catch (error) {\n      console.error('Failed to load profile data', error);\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  if (!isLoaded || loading) {\n    return (\n      <div className=\"loader-container\">\n        <div className=\"loader\"></div>\n        <p style={{ marginTop: '1rem', color: 'var(--text-secondary)' }}>Loading Profile...</p>\n      </div>\n    );\n  }\n\n  if (!isSignedIn) {\n    return (\n      <div style={{ maxWidth: '800px', margin: '4rem auto', padding: '0 20px', textAlign: 'center' }}>\n        <h2>Sign in required 🔒</h2>\n        <p style={{ color: 'var(--text-secondary)', marginTop: '10px' }}>You must be logged in to view your profile.</p>\n        <Link href=\"/\" className=\"btn btn-approve\" style={{ display: 'inline-block', marginTop: '20px' }}>Go Home</Link>\n      </div>\n    );\n  }\n\n  return (\n    <div style={{ maxWidth: '1200px', margin: '0 auto', padding: '2rem 20px' }}>\n      <header style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '3rem', borderBottom: '1px solid rgba(255,255,255,0.1)', paddingBottom: '2rem' }}>\n        <div style={{ display: 'flex', alignItems: 'center', gap: '20px' }}>\n          <img \n            src={user?.imageUrl || \"https://www.gravatar.com/avatar/00000000000000000000000000000000?d=mp&f=y\"} \n            alt=\"Profile Avatar\" \n            style={{ width: '80px', height: '80px', borderRadius: '50%', objectFit: 'cover', border: '2px solid var(--primary)' }}\n          />\n          <div>\n            <h1 style={{ margin: 0 }}>{user?.firstName || user?.username || 'Deal Hunter'}</h1>\n            <p style={{ margin: '5px 0 0 0', color: 'var(--text-secondary)' }}>{user?.emailAddresses?.[0]?.emailAddress}</p>\n          </div>\n        </div>\n        \n        <div style={{ background: 'rgba(255,255,255,0.05)', padding: '15px 30px', borderRadius: '12px', textAlign: 'center' }}>\n            <p style={{ margin: 0, fontSize: '0.9rem', color: 'var(--text-secondary)' }}>Total Reputation</p>\n            <h2 style={{ margin: '5px 0 0 0', fontSize: '2rem', color: 'var(--accent)' }}>🔥 {profileData?.totalReputation || 0}</h2>\n        </div>\n      </header>\n\n      <section style={{ marginBottom: '3rem' }}>\n          <h2 style={{ marginBottom: '1.5rem', display: 'flex', alignItems: 'center', gap: '10px' }}>\n            <span style={{ fontSize: '1.5rem' }}>📊</span> Your Hunter Stats\n          </h2>\n          <div className=\"glass-panel\" style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(200px, 1fr))', gap: '20px', padding: '20px', border: '1px solid rgba(255,255,255,0.1)' }}>\n             <div style={{ textAlign: 'center', padding: '15px' }}>\n                 <p style={{ margin: 0, color: 'var(--text-secondary)' }}>Total Submitted</p>\n                 <h3 style={{ margin: '10px 0 0 0', fontSize: '1.8rem' }}>{profileData?.deals?.length || 0}</h3>\n             </div>\n             <div style={{ textAlign: 'center', padding: '15px', borderLeft: '1px solid rgba(255,255,255,0.1)', borderRight: '1px solid rgba(255,255,255,0.1)' }}>\n                 <p style={{ margin: 0, color: 'var(--success)' }}>Approved Live</p>\n                 <h3 style={{ margin: '10px 0 0 0', fontSize: '1.8rem' }}>{profileData?.stats?.approved_count || 0}</h3>\n             </div>\n             <div style={{ textAlign: 'center', padding: '15px' }}>\n                 <p style={{ margin: 0, color: '#f5a623' }}>Pending Review</p>\n                 <h3 style={{ margin: '10px 0 0 0', fontSize: '1.8rem' }}>{profileData?.stats?.pending_count || 0}</h3>\n             </div>\n          </div>\n      </section>\n\n      <section>\n        <h2 style={{ marginBottom: '1.5rem', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>\n          <span><span style={{ fontSize: '1.5rem', marginRight: '10px' }}>🛍️</span> Deal Submissions</span>\n          <Link href=\"/submit\" className=\"btn btn-approve\" style={{ fontSize: '0.9rem', padding: '8px 16px' }}>+ Submit New</Link>\n        </h2>\n        \n        {(!profileData?.deals || profileData.deals.length === 0) ? (\n          <div style={{ textAlign: 'center', padding: '4rem 2rem', background: 'rgba(255,255,255,0.02)', borderRadius: '12px', border: '1px dashed rgba(255,255,255,0.1)' }}>\n             <p style={{ color: 'var(--text-secondary)', fontSize: '1.1rem' }}>You haven't submitted any deals yet.</p>\n             <p style={{ color: 'var(--text-secondary)' }}>Find a great discount and share it with the community to start earning reputation!</p>\n          </div>\n        ) : (\n          <div className=\"deals-grid\">\n            {profileData.deals.map((deal) => (\n              <div key={deal.id} className=\"deal-card\" style={{ display: 'flex', flexDirection: 'column' }}>\n                <div style={{ position: 'relative', background: '#fff', borderRadius: '16px 16px 0 0', height: '200px', padding: '1rem', display: 'flex', alignItems: 'center', justifyContent: 'center', overflow: 'hidden' }}>\n                  {deal.status === 'pending' && <span style={{ position: 'absolute', top: '10px', left: '10px', background: '#f5a623', color: '#000', padding: '5px 10px', borderRadius: '20px', fontSize: '0.8rem', fontWeight: 'bold', zIndex: 2 }}>⏳ Pending Approval</span>}\n                  {deal.status === 'rejected' && <span style={{ position: 'absolute', top: '10px', left: '10px', background: 'var(--danger)', color: '#fff', padding: '5px 10px', borderRadius: '20px', fontSize: '0.8rem', fontWeight: 'bold', zIndex: 2 }}>❌ Rejected</span>}\n                  {deal.status === 'approved' && <span style={{ position: 'absolute', top: '10px', left: '10px', background: 'var(--success)', color: '#fff', padding: '5px 10px', borderRadius: '20px', fontSize: '0.8rem', fontWeight: 'bold', zIndex: 2 }}>✅ Live on Store</span>}\n\n                  {deal.discount_percentage && (\n                    <span style={{ position: 'absolute', top: '10px', right: '10px', background: 'var(--danger)', color: 'white', padding: '4px 8px', borderRadius: '6px', fontSize: '0.85rem', fontWeight: 'bold', zIndex: 2 }}>\n                      {deal.discount_percentage}% OFF\n                    </span>\n                  )}\n                  {deal.image_url ? (\n                    <img src={deal.image_url} alt={deal.title} style={{ width: '100%', height: '100%', objectFit: 'contain' }} />\n                  ) : (\n                    <span style={{ color: '#ccc', fontSize: '0.9rem' }}>No Image</span>\n                  )}\n                </div>\n                <div style={{ padding: '1.5rem', display: 'flex', flexDirection: 'column', flexGrow: 1 }}>\n                  <h3 style={{ fontSize: '1.1rem', marginBottom: '1rem', display: '-webkit-box', WebkitLineClamp: '2', WebkitBoxOrient: 'vertical', overflow: 'hidden' }}>\n                    {deal.title}\n                  </h3>\n                  <div style={{ marginTop: 'auto', display: 'flex', justifyContent: 'space-between', alignItems: 'flex-end', borderTop: '1px solid rgba(255,255,255,0.1)', paddingTop: '1rem' }}>\n                      <div>\n                        {deal.discount_price && <span style={{ fontSize: '1.5rem', fontWeight: 'bold', color: 'var(--success)' }}>${parseFloat(deal.discount_price).toFixed(2)}</span>}\n                        {deal.original_price && <span style={{ fontSize: '0.9rem', textDecoration: 'line-through', color: 'var(--text-secondary)', marginLeft: '8px' }}>${parseFloat(deal.original_price).toFixed(2)}</span>}\n                      </div>\n                      <div style={{ color: 'var(--accent)', fontWeight: 'bold' }}>\n                         🔥 {deal.vote_score || 0}\n                      </div>\n                  </div>\n                </div>\n              </div>\n            ))}\n          </div>\n        )}\n      </section>\n    </div>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/r/[id]/route.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/app/submit/page.js","messages":[{"ruleId":"@next/next/no-html-link-for-pages","severity":2,"message":"Do not use an `<a>` element to navigate to `/`. Use `<Link />` from `next/link` instead. See: https://nextjs.org/docs/messages/no-html-link-for-pages","line":48,"column":11,"nodeType":"JSXOpeningElement","endLine":48,"endColumn":82}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\nimport { useState } from 'react';\nimport { useUser, SignInButton } from '@clerk/nextjs';\n\nexport default function SubmitDeal() {\n  const { isLoaded, isSignedIn, user } = useUser();\n  const [formData, setFormData] = useState({ title: '', brand: '', original_price: '', discount_price: '', url: '' });\n  const [loading, setLoading] = useState(false);\n  const [message, setMessage] = useState('');\n\n  const handleSubmit = async (e) => {\n    e.preventDefault();\n    setLoading(true);\n    setMessage('');\n    \n    try {\n      const payload = { ...formData, user: { id: user.id, email: user.primaryEmailAddress?.emailAddress, username: user.username || user.firstName } };\n      const res = await fetch('/api/deals/submit', {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify(payload)\n      });\n      \n      const data = await res.json();\n      if (res.ok) {\n        setMessage('🎉 Deal successfully submitted to the community hub!');\n        setFormData({ title: '', brand: '', original_price: '', discount_price: '', url: '' });\n      } else {\n        setMessage(`❌ Error: ${data.error}`);\n      }\n    } catch (err) {\n      console.error(err);\n      setMessage('Failed to submit deal. Try again later.');\n    } finally {\n      setLoading(false);\n    }\n  };\n\n  const handleChange = (e) => setFormData({ ...formData, [e.target.name]: e.target.value });\n\n  if (!isLoaded) return <div style={{ color: 'white', padding: '50px', textAlign: 'center' }}>Loading profile...</div>;\n\n  return (\n    <main style={{ minHeight: '100vh', background: 'var(--bg)', color: 'var(--text)', padding: '50px 20px', fontFamily: 'var(--font-geist-sans)' }}>\n      <div style={{ maxWidth: '600px', margin: '0 auto', background: 'var(--card-bg)', padding: '40px', borderRadius: '16px', border: '1px solid rgba(255,255,255,0.1)', boxShadow: '0 10px 30px rgba(0,0,0,0.5)' }}>\n        <div style={{ marginBottom: '30px' }}>\n          <h1 style={{ fontSize: '2rem', marginBottom: '10px' }}>📤 Submit a Deal</h1>\n          <a href=\"/\" style={{ color: 'var(--accent)', textDecoration: 'none' }}>← Back to Community Board</a>\n        </div>\n\n        {!isSignedIn ? (\n          <div style={{ background: 'rgba(255,255,255,0.05)', padding: '30px', borderRadius: '12px', textAlign: 'center' }}>\n            <h3 style={{ marginBottom: '20px' }}>Join the community to post deals!</h3>\n            <SignInButton mode=\"modal\">\n              <button style={{ padding: '12px 24px', background: 'var(--accent)', color: 'white', border: 'none', borderRadius: '8px', cursor: 'pointer', fontSize: '1rem', fontWeight: 'bold' }}>Sign In to Submit</button>\n            </SignInButton>\n          </div>\n        ) : (\n          <form onSubmit={handleSubmit} style={{ display: 'flex', flexDirection: 'column', gap: '20px' }}>\n            <div>\n              <label style={{ display: 'block', marginBottom: '8px', color: 'var(--text-secondary)' }}>Product Title *</label>\n              <input type=\"text\" name=\"title\" required value={formData.title} onChange={handleChange} style={{ width: '100%', padding: '12px', borderRadius: '8px', border: '1px solid #444', background: '#222', color: 'white', fontSize: '1rem' }} placeholder=\"e.g., Apple iPad Pro 11-inch (M4)\" />\n            </div>\n\n            <div>\n              <label style={{ display: 'block', marginBottom: '8px', color: 'var(--text-secondary)' }}>Product URL *</label>\n              <input type=\"url\" name=\"url\" required value={formData.url} onChange={handleChange} style={{ width: '100%', padding: '12px', borderRadius: '8px', border: '1px solid #444', background: '#222', color: 'white', fontSize: '1rem' }} placeholder=\"https://amazon.com/dp/...\" />\n              <p style={{ fontSize: '0.8rem', color: 'var(--text-secondary)', marginTop: '5px' }}>Paste the direct link. Our system handles affiliate conversion automatically.</p>\n            </div>\n\n            <div>\n              <label style={{ display: 'block', marginBottom: '8px', color: 'var(--text-secondary)' }}>Brand</label>\n              <input type=\"text\" name=\"brand\" value={formData.brand} onChange={handleChange} style={{ width: '100%', padding: '12px', borderRadius: '8px', border: '1px solid #444', background: '#222', color: 'white', fontSize: '1rem' }} placeholder=\"Apple\" />\n            </div>\n\n            <div style={{ display: 'flex', gap: '20px' }}>\n              <div style={{ flex: 1 }}>\n                <label style={{ display: 'block', marginBottom: '8px', color: 'var(--text-secondary)' }}>Original Price ($)</label>\n                <input type=\"number\" step=\"0.01\" name=\"original_price\" value={formData.original_price} onChange={handleChange} style={{ width: '100%', padding: '12px', borderRadius: '8px', border: '1px solid #444', background: '#222', color: 'white', fontSize: '1rem' }} placeholder=\"999.00\" />\n              </div>\n              <div style={{ flex: 1 }}>\n                <label style={{ display: 'block', marginBottom: '8px', color: 'var(--success)', fontWeight: 'bold' }}>Deal Price ($) *</label>\n                <input type=\"number\" step=\"0.01\" name=\"discount_price\" required value={formData.discount_price} onChange={handleChange} style={{ width: '100%', padding: '12px', borderRadius: '8px', border: '1px solid var(--success)', background: '#222', color: 'white', fontSize: '1rem' }} placeholder=\"799.00\" />\n              </div>\n            </div>\n\n            <button type=\"submit\" disabled={loading} style={{ marginTop: '10px', padding: '15px', background: loading ? '#555' : 'var(--accent)', color: 'white', border: 'none', borderRadius: '8px', fontSize: '1.1rem', fontWeight: 'bold', cursor: loading ? 'not-allowed' : 'pointer', transition: 'background 0.2s' }}>\n              {loading ? 'Submitting...' : '🚀 Submit Deal'}\n            </button>\n\n            {message && <p style={{ marginTop: '15px', textAlign: 'center', fontWeight: 'bold', color: message.includes('❌') ? 'var(--alert)' : 'var(--success)' }}>{message}</p>}\n          </form>\n        )}\n      </div>\n    </main>\n  );\n}\n","usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/check_cat.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/check_cols.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/pear/Documents/AntiGravity/Ai news/AI_Deal_Hunter/web-dashboard/check_cron.js","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecat