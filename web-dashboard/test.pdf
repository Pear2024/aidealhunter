    <script>
        require(["jquery", "ajax"], function ($, ajax) {

            $(document.body).on('click', 'a', ClickCount);

            function ClickCount(event) {
                var containsNonWhitespace = /\S/.test(linkText);

                var linkHref = $(this).attr('href');
                var linkText = $(this).text();
                var linkTextData = $(this).data('link-text');
                var widgetName = $(this).closest('[data-widget]').attr('data-widget');
                var viewName = $(this).closest('[data-viewName]').attr('data-viewName');

                if (linkTextData) {
                    linkText = linkTextData;
                }
                else {
                    linkText = (linkText && containsNonWhitespace) ? linkText : linkTextData;
                }

                ajax.json({
                    url: '/app/clickcounter',
                    data: {
                        pageName: viewName,
                        linkHref: linkHref,
                        linkText: linkText,
                        widgetName: widgetName
                    },
                    success: function (response) {
                        if (response.success) {
                            console.log('Click successfully counted', response);
                        } else {
                            console.log('Click count failed', response);
                        }
                    }
                });
            }
        })
    </script>
